{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QBZ",
  "version": "1.2.11",
  "identifier": "com.blitzfc.qbz",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$CACHE/qbz/**",
          "$CONFIG/qbz/**",
          "$DATA/qbz/**",
          "$LOCALDATA/qbz/**",
          "$HOME/.cache/qbz/**",
          "$HOME/.config/qbz/**",
          "$HOME/.local/share/qbz/**",
          "/mnt/**",
          "/media/**",
          "/run/media/**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["qobuzapp"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/vicrodh/qbz/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGN0ZDRTZERUJCQjk1ODYKUldTR2xidnJiYzUvUDMvNHpvWFpmQmQrcGVlNUt3N2g1L2dVSUU3QjlHaUw0N2R2VVNOcE5HTG0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Native Qobuz client with hi-res audio support",
    "longDescription": "QBZ is a native high-fidelity client for Qobuz\u2122 subscribers on Linux, designed for audiophiles who need bit-perfect playback without browser sample rate limitations. This application uses the Qobuz API but is not certified by Qobuz.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "linux": {
      "deb": {
        "depends": [],
        "recommends": [
          "alsa-utils"
        ]
      },
      "rpm": {
        "depends": [],
        "recommends": [
          "alsa-utils"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
