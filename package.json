{
  "name": "qbz-nix",
  "version": "1.2.10",
  "description": "Native high-fidelity client for Qobuz™ subscribers on Linux with Hi-Fi audio support (uses the Qobuz API; not certified by Qobuz)",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && vite dev",
    "dev:clean-runtime": "bash ./scripts/clean-dev-runtime.sh",
    "dev:ghost-doctor": "bash ./scripts/dev-ghost-doctor.sh",
    "dev:ghost-reset": "bash ./scripts/dev-ghost-doctor.sh --no-start",
    "dev:ultra-restore": "bash ./scripts/dev-ultra-restore.sh",
    "dev:ultra-reset": "bash ./scripts/dev-ultra-restore.sh --no-start",
    "dev:ultra-full-reset": "bash ./scripts/dev-ultra-restore.sh --full --no-start",
    "dev:reset-last-view": "bash ./scripts/dev-reset-last-view.sh",
    "dev:tauri": "./scripts/dev-with-env.sh",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:v2-backend-purity": "bash ./scripts/check-v2-backend-purity.sh",
    "check:v2-frontend-invokes": "python3 ./scripts/audit-frontend-invokes.py",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:no-t-shadow": "bash ./scripts/check-no-t-shadow.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@icons-pack/svelte-simple-icons": "^7.2.0",
    "@kawarp/core": "^1.1.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-svelte": "^1.0.1",
    "svelte-i18n": "^4.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "esbuild": "^0.25.0"
  }
}
